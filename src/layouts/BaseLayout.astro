---
export interface Props {
  title: string
  description: string
  image?: string
  pubDate?: Date
  tags?: string[]
  canonical?: string
}

const { title, description, image, pubDate, tags, canonical } = Astro.props
const site = new URL(Astro.site!)
const url = canonical ? new URL(canonical, site) : Astro.url
const ogImage = image || '/acreetionoslogo.webp'
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />

    <title>{title} | AcreetionOS Blog</title>

    <link rel="icon" type="image/webp" href="/acreetionoslogo.webp" />
    <link rel="canonical" href={url} />

    <meta property="og:type" content={pubDate ? 'article' : 'website'} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={url} />
    <meta property="og:image" content={new URL(ogImage, site)} />
    <meta name="twitter:card" content="summary_large_image" />

    {pubDate && <meta property="article:published_time" content={pubDate.toISOString()} />}
    {tags?.map(tag => <meta property="article:tag" content={tag} />)}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500;700&family=Roboto:wght@400;500;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <style>
      :root {
        --acreetion-green: #2ecc71;
        --acreetion-body-bg: #121212;
        --acreetion-panel-bg: #1a1a1a;
        --acreetion-box-bg: #222;
        --acreetion-box-border: #333;
        --acreetion-text-bright: #e5e5e5;
        --acreetion-text: #b2b2b2;
        --acreetion-code-bg: rgba(46, 204, 113, 0.1);
        --storm-color: #61afef;
        --font-sans: 'Roboto', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        --font-mono: 'Fira Code', monospace;
        --max-w: 1000px;
      }
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body { font-family: var(--font-sans); background-color: var(--acreetion-body-bg); color: var(--acreetion-text-bright); line-height: 1.6; overflow-x: hidden; display: flex; flex-direction: column; min-height: 100vh; }
      ::selection { background: rgba(46, 204, 113, 0.3); }
      ::-webkit-scrollbar { width: 10px; }
      ::-webkit-scrollbar-track { background: var(--acreetion-body-bg); }
      ::-webkit-scrollbar-thumb { background: var(--acreetion-box-border); border-radius: 10px; }
      ::-webkit-scrollbar-thumb:hover { background: var(--acreetion-green); }
      a { color: var(--acreetion-green); text-decoration: none; transition: color 0.2s; }
      a:hover { color: var(--acreetion-text-bright); text-decoration: underline; text-underline-offset: 3px; }

      .page-header {
        background-color: rgba(24,26,27,0.85);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 2px solid var(--acreetion-green);
        position: sticky;
        top: 0;
        z-index: 1000;
      }
      .header-content {
        display: flex;
        justify-content: space-between;
        align-items: center;
        max-width: 1200px;
        margin: 0 auto;
        padding: 0.6rem 2rem;
      }
      .logo {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-family: var(--font-mono);
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--acreetion-text-bright);
        text-decoration: none;
      }
      .logo-img { height: 36px; border-radius: 6px; }
      .logo span { color: var(--acreetion-green); }
      .main-nav { display: flex; gap: 0.5rem; flex-wrap: wrap; justify-content: flex-end; }
      .main-nav a {
        color: var(--acreetion-text);
        text-decoration: none;
        margin-left: 1.5rem;
        font-weight: 500;
        transition: color 0.2s;
        font-size: 0.9rem;
      }
      .main-nav a:hover { color: var(--acreetion-text-bright); text-decoration: none; }
      .main-nav a.btn-storm {
        background: transparent;
        color: var(--acreetion-green);
        border: 1px solid var(--acreetion-green);
        padding: 0.4rem 1rem;
        border-radius: 8px;
        margin-left: 0;
      }

      .page-wrapper {
        max-width: 1200px;
        margin: 2rem auto;
        padding: 0 2rem;
        flex: 1;
        width: 100%;
        display: flex;
        gap: 2rem;
      }
      .content-feed { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 1.5rem; }

      .content-box {
        background-color: var(--acreetion-box-bg);
        border: 1px solid var(--acreetion-box-border);
        border-radius: 12px;
        overflow: hidden;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
      }
      .content-box:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(0,0,0,0.4);
      }
      .box-header {
        padding: 0.8rem 1.2rem;
        border-bottom: 1px solid var(--acreetion-box-border);
        background-color: var(--acreetion-panel-bg);
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      .box-header h2 {
        font-family: var(--font-mono);
        font-size: 1.1rem;
        color: var(--acreetion-text-bright);
      }
      .box-body { padding: 1.2rem; }

      .post-header {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        color: var(--acreetion-text);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 0.5rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }
      .post-header .sep { color: var(--acreetion-box-border); }
      .post-header .tag {
        display: inline-block;
        background: rgba(46,204,113,0.1);
        color: var(--acreetion-green);
        padding: 0.1rem 0.4rem;
        border-radius: 3px;
        font-size: 0.6rem;
        text-transform: none;
        letter-spacing: normal;
        font-family: var(--font-mono);
      }

      h1 {
        font-family: var(--font-mono);
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--acreetion-text-bright);
        margin-bottom: 0.5rem;
        line-height: 1.3;
      }
      h2 {
        font-family: var(--font-mono);
        font-size: 1.2rem;
        font-weight: 600;
        color: var(--acreetion-green);
        margin-top: 2rem;
        margin-bottom: 0.5rem;
      }
      h3 {
        font-family: var(--font-mono);
        font-size: 1rem;
        font-weight: 600;
        color: var(--acreetion-text-bright);
        margin-top: 1.5rem;
        margin-bottom: 0.5rem;
      }
      p { margin-bottom: 1rem; color: var(--acreetion-text); line-height: 1.7; }
      p strong { color: var(--acreetion-text-bright); }
      ul, ol { margin-bottom: 1rem; padding-left: 1.5rem; color: var(--acreetion-text); }
      li { margin-bottom: 0.3rem; }
      blockquote {
        border-left: 3px solid var(--acreetion-green);
        padding: 0.75rem 1rem;
        margin: 1.5rem 0;
        background: var(--acreetion-code-bg);
        border-radius: 0 8px 8px 0;
        color: var(--acreetion-text);
        font-style: italic;
      }
      code {
        font-family: var(--font-mono);
        background: var(--acreetion-code-bg);
        padding: 0.2em 0.4em;
        border-radius: 4px;
        font-size: 0.85em;
        color: var(--acreetion-green);
      }
      pre {
        margin: 1.5rem 0;
        border-radius: 8px;
        overflow: hidden;
        border: 1px solid var(--acreetion-box-border);
      }
      pre code {
        padding: 1rem;
        display: block;
        overflow-x: auto;
        background: rgba(0,0,0,0.2);
        border: none;
        color: var(--acreetion-text);
      }
      table { width: 100%; border-collapse: collapse; margin: 1.5rem 0; font-size: 0.85rem; }
      th, td { padding: 0.6rem 0.8rem; border: 1px solid var(--acreetion-box-border); text-align: left; }
      th { background: var(--acreetion-panel-bg); font-family: var(--font-mono); font-weight: 600; color: var(--acreetion-text-bright); }
      td { color: var(--acreetion-text); }
      hr { border: none; border-top: 1px solid var(--acreetion-box-border); margin: 2rem 0; }
      img { max-width: 100%; border-radius: 8px; margin: 1.5rem 0; border: 1px solid var(--acreetion-box-border); }

      .page-footer {
        text-align: center;
        padding: 2rem;
        margin-top: auto;
        border-top: 1px solid var(--acreetion-box-border);
        color: #777;
        font-size: 0.9rem;
        background: var(--acreetion-panel-bg);
      }
      .page-footer p { color: #777; margin-bottom: 0.5rem; text-align: center; }
      .page-footer a { color: var(--acreetion-green); text-decoration: none; }
      .page-footer a:hover { text-decoration: underline; }
      .page-footer img { display: inline-block; border: none; margin: 0.5rem auto 0; }

      @media (max-width: 768px) {
        .header-content { flex-direction: column; gap: 0.5rem; padding: 0.5rem 1rem; }
        .logo { font-size: 1.2rem; }
        .main-nav a { margin-left: 0.75rem; font-size: 0.8rem; }
        .page-wrapper { flex-direction: column; padding: 0 1rem; margin: 1rem auto; }
        h1 { font-size: 1.2rem; }
        .box-header h2 { font-size: 0.9rem; }
      }
    </style>
  </head>
  <body>
    <header class="page-header">
      <div class="header-content">
        <a href="/" class="logo">
          <img src="/acreetionoslogo.webp" alt="AcreetionOS" class="logo-img" width="36" height="36" />
          Acreetion<span>OS</span>
        </a>
        <nav class="main-nav">
          <a href="/">Blog</a>
          <a href="https://acreetionos.org" target="_blank">Project</a>
          <a href="https://discord.acreetionos.org" target="_blank">Discord</a>
          <a href="https://acreetionos.org/wiki.html" target="_blank" class="btn-storm">Wiki</a>
        </nav>
      </div>
    </header>

    <div class="page-wrapper">
      <div class="content-feed">
        <slot />
      </div>
    </div>

    <footer class="page-footer">
      <p>AcreetionOS Blog — <a href="https://acreetionos.org">acreetionos.org</a> &middot; <a href="https://discord.acreetionos.org">Discord</a> &middot; <a href="/rss.xml">RSS</a></p>
      <a href="https://natalie.acreetionos.org" target="_blank"><img src="/natalie-badge.svg" alt="Maintained by Natalie Spiva" width="220" height="50" /></a>
    </footer>
  </body>
</html>
