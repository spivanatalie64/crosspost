---
export interface Props {
  title: string
  description: string
  image?: string
  pubDate?: Date
  tags?: string[]
  canonical?: string
}

const { title, description, image, pubDate, tags, canonical } = Astro.props
const site = new URL(Astro.site!)
const url = canonical ? new URL(canonical, site) : Astro.url
const ogImage = image || '/acreetionoslogo.webp'
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />

    <title>{title} | AcreetionOS Blog</title>

    <link rel="icon" type="image/webp" href="/acreetionoslogo.webp" />
    <link rel="canonical" href={url} />

    <meta property="og:type" content={pubDate ? 'article' : 'website'} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={url} />
    <meta property="og:image" content={new URL(ogImage, site)} />
    <meta name="twitter:card" content="summary_large_image" />

    {pubDate && <meta property="article:published_time" content={pubDate.toISOString()} />}
    {tags?.map(tag => <meta property="article:tag" content={tag} />)}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500;700&family=Roboto:wght@400;500;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <style>
      :root {
        --green: #2ecc71;
        --green-dim: rgba(46, 204, 113, 0.15);
        --bg: #0c0f0e;
        --bg-card: #141a17;
        --bg-panel: #1a221e;
        --border: #1e2a24;
        --border-bright: #2a3a32;
        --fg: #e8ece9;
        --fg-muted: #8a9a92;
        --fg-dim: #5a6a62;
        --glow: rgba(46, 204, 113, 0.06);
        --code-bg: rgba(46, 204, 113, 0.06);
        --font-sans: 'Roboto', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        --font-mono: 'Fira Code', monospace;
        --max-w: 780px;
      }

      * { margin: 0; padding: 0; box-sizing: border-box; }

      body {
        font-family: var(--font-sans);
        background: var(--bg);
        color: var(--fg);
        line-height: 1.7;
        -webkit-font-smoothing: antialiased;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        background-image:
          radial-gradient(ellipse at 20% 50%, rgba(46, 204, 113, 0.03) 0%, transparent 50%),
          radial-gradient(ellipse at 80% 20%, rgba(46, 204, 113, 0.02) 0%, transparent 50%);
      }

      ::selection { background: rgba(46, 204, 113, 0.3); color: #fff; }
      ::-webkit-scrollbar { width: 8px; }
      ::-webkit-scrollbar-track { background: var(--bg); }
      ::-webkit-scrollbar-thumb { background: var(--border-bright); border-radius: 10px; }
      ::-webkit-scrollbar-thumb:hover { background: var(--green); }

      a { color: var(--green); text-decoration: none; transition: all 0.2s; }
      a:hover { text-decoration: underline; text-underline-offset: 3px; color: #3ddc84; }

      header {
        background: rgba(12, 15, 14, 0.8);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border-bottom: 1px solid var(--border);
        position: sticky;
        top: 0;
        z-index: 1000;
      }

      .header-content {
        max-width: var(--max-w);
        margin: 0 auto;
        padding: 0 1.25rem;
        height: 64px;
        display: flex;
        align-items: center;
        gap: 1rem;
      }

      .logo {
        display: flex;
        align-items: center;
        gap: 0.7rem;
        font-family: var(--font-mono);
        font-size: 1.15rem;
        font-weight: 700;
        color: var(--fg) !important;
        text-decoration: none !important;
        letter-spacing: -0.02em;
      }

      .logo-img {
        height: 36px;
        width: 36px;
        border-radius: 8px;
        transition: transform 0.3s ease;
      }
      .logo:hover .logo-img { transform: scale(1.05); }
      .logo span { color: var(--green); }

      .nav-links { margin-left: auto; display: flex; gap: 0.25rem; }
      .nav-links a {
        color: var(--fg-muted);
        font-weight: 450;
        font-size: 0.85rem;
        text-decoration: none !important;
        padding: 0.45rem 0.9rem;
        border-radius: 8px;
        transition: all 0.2s;
      }
      .nav-links a:hover { color: var(--fg); background: rgba(46, 204, 113, 0.06); }

      .page-wrapper {
        max-width: var(--max-w);
        margin: 3rem auto;
        padding: 0 1.25rem;
        flex: 1;
        width: 100%;
      }

      .content-box {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 16px;
        overflow: hidden;
        transition: all 0.3s ease;
      }

      .content-box:hover {
        border-color: var(--border-bright);
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
      }

      .box-header {
        padding: 1rem 1.5rem;
        border-bottom: 1px solid var(--border);
        background: var(--bg-panel);
      }

      .box-header h2 {
        font-family: var(--font-mono);
        font-size: 1rem;
        color: var(--fg);
        font-weight: 600;
        letter-spacing: -0.01em;
      }

      .box-body { padding: 1.5rem; }

      h1 {
        font-family: var(--font-mono);
        font-size: 1.7rem;
        font-weight: 700;
        color: var(--fg);
        margin-bottom: 0.75rem;
        line-height: 1.35;
        letter-spacing: -0.03em;
      }

      h2 {
        font-family: var(--font-mono);
        font-size: 1.25rem;
        font-weight: 600;
        color: var(--green);
        margin-top: 2.5rem;
        margin-bottom: 0.75rem;
        letter-spacing: -0.02em;
      }

      h3 {
        font-family: var(--font-mono);
        font-size: 1.05rem;
        font-weight: 600;
        color: var(--fg);
        margin-top: 1.75rem;
        margin-bottom: 0.5rem;
      }

      p { margin-bottom: 1rem; color: var(--fg-muted); line-height: 1.8; font-size: 0.95rem; }
      p strong { color: var(--fg); }

      ul, ol { margin-bottom: 1rem; padding-left: 1.5rem; color: var(--fg-muted); }
      li { margin-bottom: 0.3rem; }

      blockquote {
        border-left: 3px solid var(--green);
        padding: 0.75rem 1rem;
        margin: 1.5rem 0;
        background: var(--code-bg);
        border-radius: 0 8px 8px 0;
        color: var(--fg-muted);
        font-style: italic;
      }

      code {
        font-family: var(--font-mono);
        background: var(--code-bg);
        padding: 0.2em 0.45em;
        border-radius: 6px;
        font-size: 0.82em;
        color: var(--green);
      }

      pre {
        margin: 1.5rem 0;
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid var(--border);
        background: rgba(0,0,0,0.2);
      }

      pre code {
        padding: 1.25rem;
        display: block;
        overflow-x: auto;
        background: transparent;
        border: none;
        color: var(--fg-muted);
        font-size: 0.82rem;
        line-height: 1.6;
      }

      img { max-width: 100%; border-radius: 12px; margin: 1.5rem 0; border: 1px solid var(--border); }
      hr { border: none; border-top: 1px solid var(--border); margin: 2.5rem 0; }

      table {
        width: 100%;
        border-collapse: collapse;
        margin: 1.5rem 0;
        font-size: 0.85rem;
      }
      th, td {
        padding: 0.65rem 0.85rem;
        border: 1px solid var(--border);
        text-align: left;
      }
      th {
        background: var(--bg-panel);
        font-family: var(--font-mono);
        font-weight: 600;
        color: var(--fg);
        font-size: 0.8rem;
      }
      td { color: var(--fg-muted); }

      .meta {
        color: var(--fg-dim);
        font-size: 0.8rem;
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        flex-wrap: wrap;
      }

      .tag {
        display: inline-block;
        background: var(--green-dim);
        color: var(--green);
        padding: 0.15rem 0.55rem;
        border-radius: 6px;
        font-size: 0.7rem;
        font-weight: 500;
        border: 1px solid rgba(46, 204, 113, 0.15);
      }

      .post-list { list-style: none; display: flex; flex-direction: column; gap: 0.85rem; }
      .post-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 1.4rem;
        transition: all 0.25s ease;
        position: relative;
        overflow: hidden;
      }

      .post-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 3px;
        height: 100%;
        background: var(--green);
        opacity: 0;
        transition: opacity 0.25s ease;
      }

      .post-card:hover {
        border-color: var(--border-bright);
        transform: translateY(-2px);
        box-shadow: 0 12px 40px rgba(0, 0, 0, 0.3);
        background: linear-gradient(135deg, var(--bg-card), rgba(46, 204, 113, 0.02));
      }

      .post-card:hover::before { opacity: 1; }

      .post-card-title {
        font-family: var(--font-mono);
        font-size: 1rem;
        font-weight: 600;
        color: var(--fg) !important;
        text-decoration: none !important;
        transition: color 0.2s;
        line-height: 1.4;
      }

      .post-card:hover .post-card-title { color: var(--green) !important; }

      .entry-header {
        padding: 1.5rem;
        border-bottom: 1px solid var(--border);
        background: var(--bg-panel);
      }

      footer {
        border-top: 1px solid var(--border);
        padding: 2.5rem 1rem;
        text-align: center;
        background: var(--bg-panel);
        margin-top: auto;
      }

      footer p { color: var(--fg-dim); margin-bottom: 0.3rem; text-align: center; font-size: 0.8rem; }
      footer a { color: var(--fg-muted); text-decoration: none; transition: color 0.2s; }
      footer a:hover { color: var(--green); text-decoration: none; }
    </style>
  </head>
  <body>
    <header>
      <div class="header-content">
        <a href="/" class="logo">
          <img src="/acreetionoslogo.webp" alt="AcreetionOS" class="logo-img" width="40" height="40" />
          Acreetion<span>OS</span>
        </a>
        <nav class="nav-links">
          <a href="/">Blog</a>
          <a href="https://acreetionos.org" target="_blank">Project</a>
          <a href="https://discord.acreetionos.org" target="_blank">Discord</a>
        </nav>
      </div>
    </header>

    <div class="page-wrapper">
      <slot />
    </div>

    <footer>
      <p>
        <a href="https://acreetionos.org">AcreetionOS</a>
        &middot; <a href="https://discord.acreetionos.org">Discord</a>
        &middot; <a href="/rss.xml">RSS</a>
      </p>
      <div style="margin-top: 0.75rem;">
        <a href="https://natalie.acreetionos.org" target="_blank" style="text-decoration: none;">
          <img src="/natalie-badge.svg" alt="Maintained by Natalie Spiva" width="280" height="65" style="display: inline-block; border: none; margin: 0;" />
        </a>
      </div>
    </footer>
  </body>
</html>
