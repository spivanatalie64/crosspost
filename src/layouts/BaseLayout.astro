---
export interface Props {
  title: string
  description: string
  image?: string
  pubDate?: Date
  tags?: string[]
  canonical?: string
}

const { title, description, image, pubDate, tags, canonical } = Astro.props
const site = new URL(Astro.site!)
const url = canonical ? new URL(canonical, site) : Astro.url
const ogImage = image || '/acreetionoslogo.webp'
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />

    <title>{title} | AcreetionOS Blog</title>

    <link rel="icon" type="image/webp" href="/acreetionoslogo.webp" />
    <link rel="canonical" href={url} />

    <meta property="og:type" content={pubDate ? 'article' : 'website'} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={url} />
    <meta property="og:image" content={new URL(ogImage, site)} />
    <meta name="twitter:card" content="summary_large_image" />

    {pubDate && <meta property="article:published_time" content={pubDate.toISOString()} />}
    {tags?.map(tag => <meta property="article:tag" content={tag} />)}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500;700&family=Roboto:wght@400;500;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <style>
      :root {
        --acreetion-green: #2ecc71;
        --acreetion-body-bg: #121212;
        --acreetion-panel-bg: #1a1a1a;
        --acreetion-box-bg: #222;
        --acreetion-box-border: #333;
        --acreetion-text-bright: #e5e5e5;
        --acreetion-text: #b2b2b2;
        --acreetion-code-bg: rgba(46, 204, 113, 0.1);
        --font-sans: 'Roboto', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        --font-mono: 'Fira Code', monospace;
        --max-w: 800px;
      }

      * { margin: 0; padding: 0; box-sizing: border-box; }

      body {
        font-family: var(--font-sans);
        background-color: var(--acreetion-body-bg);
        color: var(--acreetion-text-bright);
        line-height: 1.7;
        -webkit-font-smoothing: antialiased;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      ::selection { background: rgba(46, 204, 113, 0.3); color: #fff; }
      ::-webkit-scrollbar { width: 10px; }
      ::-webkit-scrollbar-track { background: var(--acreetion-body-bg); }
      ::-webkit-scrollbar-thumb { background: var(--acreetion-box-border); border-radius: 10px; }
      ::-webkit-scrollbar-thumb:hover { background: var(--acreetion-green); }

      a { color: var(--acreetion-green); text-decoration: none; transition: color 0.2s; }
      a:hover { text-decoration: underline; text-underline-offset: 3px; }

      header {
        background-color: rgba(24, 26, 27, 0.85);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 2px solid var(--acreetion-green);
        position: sticky;
        top: 0;
        z-index: 1000;
      }

      .header-content {
        max-width: var(--max-w);
        margin: 0 auto;
        padding: 0 1rem;
        height: 60px;
        display: flex;
        align-items: center;
        gap: 1rem;
      }

      .logo {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-family: var(--font-mono);
        font-size: 1.3rem;
        font-weight: 700;
        color: var(--acreetion-text-bright) !important;
        text-decoration: none !important;
      }

      .logo-img {
        height: 36px;
        width: 36px;
        border-radius: 6px;
      }

      .logo span { color: var(--acreetion-green); }

      .nav-links { margin-left: auto; display: flex; gap: 1.5rem; }
      .nav-links a {
        color: var(--acreetion-text);
        font-weight: 500;
        font-size: 0.9rem;
        text-decoration: none;
        transition: color 0.2s;
      }
      .nav-links a:hover { color: var(--acreetion-text-bright); }

      .page-wrapper {
        max-width: var(--max-w);
        margin: 2rem auto;
        padding: 0 1rem;
        flex: 1;
        width: 100%;
      }

      .content-box {
        background-color: var(--acreetion-box-bg);
        border: 1px solid var(--acreetion-box-border);
        border-radius: 8px;
        overflow: hidden;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
      }

      .content-box:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
      }

      .box-header {
        padding: 0.8rem 1.2rem;
        border-bottom: 1px solid var(--acreetion-box-border);
        background-color: var(--acreetion-panel-bg);
      }

      .box-header h2 {
        font-family: var(--font-mono);
        font-size: 1.2rem;
        color: var(--acreetion-text-bright);
      }

      .box-body { padding: 1.2rem; }

      h1 {
        font-family: var(--font-mono);
        font-size: 1.8rem;
        color: var(--acreetion-green);
        margin-bottom: 0.75rem;
        line-height: 1.3;
        letter-spacing: -0.02em;
      }

      h2 {
        font-family: var(--font-mono);
        font-size: 1.3rem;
        color: var(--acreetion-green);
        margin-top: 2rem;
        margin-bottom: 0.5rem;
      }

      h3 {
        font-family: var(--font-mono);
        font-size: 1.1rem;
        color: var(--acreetion-text-bright);
        margin-top: 1.5rem;
        margin-bottom: 0.5rem;
      }

      p { margin-bottom: 1rem; color: var(--acreetion-text); line-height: 1.8; }
      p strong { color: var(--acreetion-text-bright); }

      ul, ol { margin-bottom: 1rem; padding-left: 1.5rem; color: var(--acreetion-text); }
      li { margin-bottom: 0.3rem; }

      blockquote {
        border-left: 3px solid var(--acreetion-green);
        padding-left: 1rem;
        margin: 1.5rem 0;
        color: var(--acreetion-text);
        font-style: italic;
      }

      code {
        font-family: var(--font-mono);
        background: var(--acreetion-code-bg);
        padding: 0.2em 0.4em;
        border-radius: 4px;
        font-size: 0.85em;
        color: var(--acreetion-green);
      }

      pre {
        margin: 1.5rem 0;
        border-radius: 8px;
        overflow: hidden;
        border: 1px solid var(--acreetion-box-border);
      }

      pre code {
        padding: 1rem;
        display: block;
        overflow-x: auto;
        background: var(--acreetion-panel-bg);
        border: none;
        color: var(--acreetion-text);
      }

      img { max-width: 100%; border-radius: 8px; margin: 1.5rem 0; border: 1px solid var(--acreetion-box-border); }
      hr { border: none; border-top: 1px solid var(--acreetion-box-border); margin: 2rem 0; }

      .meta {
        color: var(--acreetion-text);
        font-size: 0.85rem;
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        flex-wrap: wrap;
      }

      .tag {
        display: inline-block;
        background: rgba(46, 204, 113, 0.1);
        color: var(--acreetion-green);
        padding: 0.15rem 0.55rem;
        border-radius: 4px;
        font-size: 0.75rem;
        font-weight: 500;
        border: 1px solid rgba(46, 204, 113, 0.2);
      }

      .post-list { list-style: none; display: flex; flex-direction: column; gap: 1rem; }
      .post-card {
        background-color: var(--acreetion-box-bg);
        border: 1px solid var(--acreetion-box-border);
        border-radius: 8px;
        padding: 1.25rem;
        transition: border-color 0.2s, transform 0.2s;
      }

      .post-card:hover {
        border-color: var(--acreetion-green);
        transform: translateY(-2px);
        box-shadow: 0 0 20px rgba(46, 204, 113, 0.08);
      }

      .post-card-title {
        font-family: var(--font-mono);
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--acreetion-text-bright) !important;
        text-decoration: none !important;
        transition: color 0.2s;
      }

      .post-card:hover .post-card-title { color: var(--acreetion-green) !important; }

      .entry-header {
        border-bottom: 1px solid var(--acreetion-box-border);
        padding-bottom: 1.5rem;
        margin-bottom: 2rem;
      }

      footer {
        border-top: 1px solid var(--acreetion-box-border);
        padding: 2rem 1rem;
        text-align: center;
        color: #777;
        font-size: 0.85rem;
        background-color: var(--acreetion-panel-bg);
        margin-top: auto;
      }

      footer p { color: #777; margin-bottom: 0.3rem; text-align: center; }
      footer a { color: var(--acreetion-green); text-decoration: none; }
      footer a:hover { text-decoration: underline; }

      .maintained-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        font-size: 0.8rem;
        color: var(--acreetion-text);
        margin-top: 0.5rem;
        opacity: 0.7;
      }
    </style>
  </head>
  <body>
    <header>
      <div class="header-content">
        <a href="/" class="logo">
          <img src="/acreetionoslogo.webp" alt="AcreetionOS" class="logo-img" width="40" height="40" />
          Acreetion<span>OS</span>
        </a>
        <nav class="nav-links">
          <a href="/">Blog</a>
          <a href="https://acreetionos.org" target="_blank">Project</a>
          <a href="https://discord.acreetionos.org" target="_blank">Discord</a>
        </nav>
      </div>
    </header>

    <div class="page-wrapper">
      <slot />
    </div>

    <footer>
      <p>
        <a href="https://acreetionos.org">AcreetionOS</a>
        &middot; <a href="https://discord.acreetionos.org">Discord</a>
        &middot; <a href="/rss.xml">RSS</a>
      </p>
      <div style="margin-top: 0.75rem;">
        <img src="/natalie-badge.svg" alt="Maintained by Natalie Spiva" width="280" height="65" style="display: inline-block; border: none; margin: 0;" />
      </div>
    </footer>
  </body>
</html>
