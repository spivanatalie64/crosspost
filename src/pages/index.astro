---
import BaseLayout from '../layouts/BaseLayout.astro'
import { getCollection } from 'astro:content'

const posts = await getCollection('posts', ({ data }) => !data.draft)
posts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
---

<BaseLayout title="Blog" description="Latest news and updates from the AcreetionOS operating system project. Maintained by Natalie Spiva.">
  <article class="content-box">
    <div class="box-header">
      <h2><i class="bi bi-newspaper"></i> AcreetionOS Blog</h2>
    </div>
    <div class="box-body">
      <p style="margin: 0; color: var(--acreetion-text);">
        Updates, development progress, and community news. <a href="/rss.xml"><i class="bi bi-rss"></i> RSS</a>
      </p>
    </div>
  </article>

  {posts.length === 0 && (
    <article class="content-box">
      <div class="box-body" style="text-align: center; padding: 2rem;">
        <p style="margin: 0;">No posts yet. Coming soon.</p>
      </div>
    </article>
  )}

  {posts.map((post) => (
    <article class="content-box post-card">
      <div class="box-body">
        <div class="post-header">
          <span>{post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
          <span class="sep">|</span>
          {post.data.tags?.map(tag => <span class="tag">{tag}</span>)}
        </div>
        <a href={`/posts/${post.id}`} style="text-decoration: none;">
          <h1 style="font-size: 1.2rem; color: var(--acreetion-text-bright);">{post.data.title}</h1>
        </a>
        <p style="margin: 0.4rem 0 0; color: var(--acreetion-text);">
          {post.data.description}
        </p>
      </div>
    </article>
  ))}
</BaseLayout>
