---
import BaseLayout from '../layouts/BaseLayout.astro'
import { getCollection } from 'astro:content'

const posts = await getCollection('posts', ({ data }) => !data.draft)
posts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
---

<BaseLayout title="Blog" description="Latest news and updates from the acreetionos operating system project.">
  <h1>acreetionos Blog</h1>
  <p style="margin-bottom: 2rem;">
    Updates, development progress, and community news from the acreetionos project.
    <a href="/rss.xml">Subscribe via RSS</a>
  </p>

  {posts.length === 0 && <p>No posts yet. Coming soon.</p>}

  <ul style="list-style: none; display: flex; flex-direction: column; gap: 1.5rem;">
    {posts.map((post) => (
      <li style="border: 1px solid var(--border); border-radius: 8px; padding: 1.25rem;">
        <a href={`/posts/${post.id}`} style="font-size: 1.2rem; font-weight: 600; color: var(--fg);">
          {post.data.title}
        </a>
        <div class="meta" style="margin-top: 0.3rem;">
          {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          {post.data.tags?.map(tag => <span class="tag">{tag}</span>)}
        </div>
        <p style="margin: 0;">{post.data.description}</p>
      </li>
    ))}
  </ul>
</BaseLayout>
