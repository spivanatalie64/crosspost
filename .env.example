# Crosspost Configuration
# At least one platform must be configured.
# Copy this to .env and fill in your credentials.

# --- Mastodon (free) ---
# Generate an access token at Preferences → Development → New Application
MASTODON_INSTANCE=https://mastodon.social
MASTODON_ACCESS_TOKEN=

# --- Facebook (browser-based, Group) ---
# Uses Playwright to post as yourself. Store credentials in GitHub Secrets.
FACEBOOK_EMAIL=
FACEBOOK_PASSWORD=
FACEBOOK_GROUP_ID=574717645277790

# --- Threads (free) ---
# Get a user ID and access token from the Meta Threads API
THREADS_USER_ID=
THREADS_ACCESS_TOKEN=

# --- X / Twitter ($100/mo Basic tier) ---
# Generate keys at https://developer.twitter.com
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# --- AI Generation (optional) ---
# Used when running with --generate flag
# Get a free API key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
CONTENT_PROMPT=technology and programming news
